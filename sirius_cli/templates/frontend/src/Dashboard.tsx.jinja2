import React, { useEffect, useState } from 'react'
import { Link } from 'react-router-dom'
import { Table, Layers, Hash, Calendar, ArrowRight, RefreshCw, BarChart2 } from 'lucide-react'
import { BarChart, Bar, XAxis, YAxis, Tooltip, ResponsiveContainer, CartesianGrid } from 'recharts'

const API_BASE = import.meta.env.VITE_API_URL || 'http://localhost:8000'

interface TableMetadata {
  name: string
  count: number
  columns: Array<{ name: string; type: string; is_pk: boolean }>
}

export default function Dashboard() {
  const [metadata, setMetadata] = useState<TableMetadata[]>([])
  const [loading, setLoading] = useState(true)
  const [error, setError] = useState<string | null>(null)
  const [tableData, setTableData] = useState<Record<string, any[]>>({})
  const [chartsLoading, setChartsLoading] = useState<Record<string, boolean>>({})
  const [chartsError, setChartsError] = useState<Record<string, string | null>>({})

  const fetchAllTableData = async (tables: TableMetadata[]) => {
    tables.forEach(async (table) => {
      try {
        setChartsLoading(prev => ({ ...prev, [table.name]: true }))
        const res = await fetch(`${API_BASE}/api/${table.name}?limit=500`{% if auth %}, { headers: { Authorization: `Bearer ${localStorage.getItem('token')}` } }{% endif %})
        if (!res.ok) throw new Error(`Failed to fetch ${table.name} data`)
        const data = await res.json()
        setTableData(prev => ({ ...prev, [table.name]: data }))
        setChartsError(prev => ({ ...prev, [table.name]: null }))
      } catch (err: any) {
        setChartsError(prev => ({ ...prev, [table.name]: err.message || 'Failed to load' }))
      } finally {
        setChartsLoading(prev => ({ ...prev, [table.name]: false }))
      }
    })
  }

  const fetchMetadata = async () => {
    try {
      setLoading(true)
      const res = await fetch(`${API_BASE}/api/metadata`{% if auth %}, { headers: { Authorization: `Bearer ${localStorage.getItem('token')}` } }{% endif %})
      if (!res.ok) throw new Error('Failed to fetch system metadata')
      const data = await res.json()
      setMetadata(data)
      setError(null)
      fetchAllTableData(data)
    } catch (err: any) {
      setError(err.message || 'Something went wrong')
    } finally {
      setLoading(false)
    }
  }

  useEffect(() => {
    fetchMetadata()
  }, [])

  const findDateColumn = (table: TableMetadata) => {
    const dateTimeCol = table.columns.find(col => col.type === 'DateTime')
    if (dateTimeCol) return dateTimeCol.name

    const nameMatch = table.columns.find(col => {
      const n = col.name.toLowerCase()
      return n === 'created_at' || n === 'updated_at' || n.endsWith('_at') || n.endsWith('_date') || n === 'date'
    })
    return nameMatch ? nameMatch.name : null
  }

  const getChartData = (table: TableMetadata) => {
    const data = tableData[table.name] || []
    const dateFieldName = findDateColumn(table)

    if (!dateFieldName || data.length === 0) {
      return {
        data: [{ name: 'Total Records', count: table.count }],
        isFallback: true,
        dateField: null
      }
    }

    const counts: Record<string, number> = {}
    data.forEach(row => {
      const rawVal = row[dateFieldName]
      if (!rawVal) return
      
      let dateStr = ''
      try {
        const dateObj = new Date(rawVal)
        if (!isNaN(dateObj.getTime())) {
          dateStr = dateObj.toISOString().split('T')[0]
        } else {
          dateStr = String(rawVal).split('T')[0].split(' ')[0]
        }
      } catch {
        dateStr = String(rawVal).split('T')[0].split(' ')[0]
      }
      
      if (dateStr) {
        counts[dateStr] = (counts[dateStr] || 0) + 1
      }
    })

    const chartData = Object.entries(counts).map(([date, count]) => ({
      name: date,
      count
    }))

    chartData.sort((a, b) => new Date(a.name).getTime() - new Date(b.name).getTime())

    if (chartData.length === 0) {
      return {
        data: [{ name: 'Total Records', count: table.count }],
        isFallback: true,
        dateField: null
      }
    }

    return {
      data: chartData.slice(-15),
      isFallback: false,
      dateField: dateFieldName
    }
  }

  const totalTables = metadata.length
  const totalRows = metadata.reduce((acc, curr) => acc + curr.count, 0)

  return (
    <div className="space-y-8">
      {/* Top Banner */}
      <div className="flex flex-col md:flex-row md:items-center justify-between gap-4">
        <div>
          <h2 className="text-3xl font-outfit font-bold tracking-tight bg-gradient-to-r from-white to-slate-400 bg-clip-text text-transparent">
            System Overview
          </h2>
          <p className="text-slate-400 mt-1 text-sm font-sans">
            Overview of autogenerated tables, records, and database stats.
          </p>
        </div>
        <button
          onClick={fetchMetadata}
          className="flex items-center gap-2 px-4 py-2 bg-slate-900 border border-slate-800 rounded-xl text-xs font-semibold hover:bg-slate-800 transition-all text-slate-300"
        >
          <RefreshCw className={`w-3.5 h-3.5 ${loading ? 'animate-spin' : ''}`} />
          Refresh Stats
        </button>
      </div>

      {/* Stats Grid */}
      <div className="grid grid-cols-1 md:grid-cols-2 lg:grid-cols-3 gap-6">
        <div className="p-6 bg-slate-900/40 border border-slate-900 rounded-2xl relative overflow-hidden group hover:border-slate-800 transition-all duration-300">
          <div className="absolute top-0 right-0 p-8 text-brand-500/10 transition-transform duration-300 group-hover:scale-110">
            <Layers className="w-24 h-24" />
          </div>
          <p className="text-xs font-semibold text-slate-500 uppercase tracking-widest">Total Tables</p>
          <p className="text-4xl font-bold font-outfit mt-2">{totalTables}</p>
          <p className="text-xs text-slate-400 mt-2">Discovered in schema parse</p>
        </div>

        <div className="p-6 bg-slate-900/40 border border-slate-900 rounded-2xl relative overflow-hidden group hover:border-slate-800 transition-all duration-300">
          <div className="absolute top-0 right-0 p-8 text-brand-500/10 transition-transform duration-300 group-hover:scale-110">
            <Hash className="w-24 h-24" />
          </div>
          <p className="text-xs font-semibold text-slate-500 uppercase tracking-widest">Total Rows</p>
          <p className="text-4xl font-bold font-outfit mt-2">{totalRows}</p>
          <p className="text-xs text-slate-400 mt-2">Stored across all tables</p>
        </div>

        <div className="p-6 bg-slate-900/40 border border-slate-900 rounded-2xl relative overflow-hidden group hover:border-slate-800 transition-all duration-300 md:col-span-2 lg:col-span-1">
          <div className="absolute top-0 right-0 p-8 text-emerald-500/10 transition-transform duration-300 group-hover:scale-110">
            <Calendar className="w-24 h-24" />
          </div>
          <p className="text-xs font-semibold text-slate-500 uppercase tracking-widest">Server Status</p>
          <p className="text-4xl font-bold font-outfit mt-2">Active</p>
          <p className="text-xs text-slate-400 mt-2 flex items-center gap-1.5">
            <span className="h-1.5 w-1.5 rounded-full bg-emerald-500"></span> Live sync connection
          </p>
        </div>
      </div>

      {/* Entity Charts Grid */}
      {!loading && !error && metadata.length > 0 && (
        <div className="space-y-6">
          <h3 className="text-lg font-bold font-outfit text-slate-200 flex items-center gap-2">
            <BarChart2 className="w-5 h-5 text-brand-400" />
            Entity Trends & Activity
          </h3>
          <div className="grid grid-cols-1 lg:grid-cols-2 gap-6">
            {metadata.map((table) => {
              const { data: chartData, isFallback, dateField } = getChartData(table)
              const tableLoading = chartsLoading[table.name]
              const tableError = chartsError[table.name]
              const hasNoData = !tableLoading && (!tableData[table.name] || tableData[table.name].length === 0)

              return (
                <div key={table.name} className="p-6 bg-slate-900/30 border border-slate-900 rounded-2xl flex flex-col justify-between h-80">
                  <div className="flex items-center justify-between mb-4">
                    <div>
                      <h4 className="text-sm font-bold text-white capitalize font-outfit">
                        {table.name.replace('_', ' ')}
                      </h4>
                      <p className="text-[10px] text-slate-500 mt-0.5">
                        {isFallback ? 'Total records count fallback' : `Trend grouped by date (${dateField})`}
                      </p>
                    </div>
                    <span className="text-[10px] px-2 py-0.5 bg-slate-800 text-slate-400 rounded-md font-mono">
                      {table.count} total rows
                    </span>
                  </div>

                  <div className="flex-1 w-full relative min-h-0 flex items-center justify-center">
                    {tableLoading ? (
                      <div className="w-full h-full flex flex-col gap-3 justify-center items-center animate-pulse">
                        <div className="w-full h-40 bg-slate-800/20 rounded-xl" />
                        <div className="w-1/3 h-3.5 bg-slate-800/20 rounded" />
                      </div>
                    ) : tableError ? (
                      <div className="text-center p-4 border border-red-500/10 bg-red-500/5 rounded-xl">
                        <p className="text-xs text-red-400 font-semibold">{tableError}</p>
                      </div>
                    ) : hasNoData ? (
                      <div className="text-center py-8">
                        <p className="text-xs text-slate-500 font-medium">No records available for this entity</p>
                      </div>
                    ) : (
                      <div className="h-full w-full">
                        <ResponsiveContainer width="100%" height="100%">
                          <BarChart data={chartData} margin={ { top: 10, right: 10, left: -25, bottom: 0 } }>
                            <CartesianGrid strokeDasharray="3 3" stroke="#1e293b" vertical={false} />
                            <XAxis 
                              dataKey="name" 
                              stroke="#64748b" 
                              fontSize={10} 
                              tickLine={false}
                              axisLine={false}
                              tickFormatter={(val) => {
                                if (isFallback) return val
                                const parts = val.split('-')
                                return parts.length >= 3 ? `${parts[1]}/${parts[2]}` : val
                              }}
                            />
                            <YAxis 
                              stroke="#64748b" 
                              fontSize={10}
                              tickLine={false}
                              axisLine={false}
                              tickFormatter={(val) => val >= 1000 ? `${(val / 1000).toFixed(1)}k` : val}
                            />
                            <Tooltip 
                              cursor={ { fill: '#0f172a' } }
                              contentStyle={ { backgroundColor: '#0f172a', borderColor: '#1e293b', borderRadius: '0.75rem' } }
                              itemStyle={ { color: '#38bdf8' } }
                              labelStyle={ { color: '#94a3b8', textTransform: 'capitalize', marginBottom: '4px' } }
                              formatter={(value: number) => [value, 'Count']}
                            />
                            <Bar 
                              dataKey="count" 
                              fill="#0ea5e9" 
                              radius={[4, 4, 0, 0]} 
                              barSize={isFallback ? 50 : 25}
                              animationDuration={1000}
                            />
                          </BarChart>
                        </ResponsiveContainer>
                      </div>
                    )}
                  </div>
                </div>
              )
            })}
          </div>
        </div>
      )}

      {/* Tables section */}
      <div>
        <h3 className="text-lg font-bold font-outfit text-slate-200 mb-6 flex items-center gap-2">
          <Table className="w-5 h-5 text-brand-400" />
          Entity Navigator
        </h3>

        {loading ? (
          <div className="grid grid-cols-1 md:grid-cols-2 gap-6">
            {[1, 2].map((n) => (
              <div key={n} className="h-48 rounded-2xl bg-slate-900/20 border border-slate-900/50 animate-pulse" />
            ))}
          </div>
        ) : error ? (
          <div className="p-6 border border-red-500/20 bg-red-500/5 text-red-400 rounded-2xl">
            <p className="font-semibold text-sm">Failed to connect to backend server</p>
            <p className="text-xs mt-1 text-red-400/80">Make sure the FastAPI backend is running on {API_BASE}.</p>
          </div>
        ) : (
          <div className="grid grid-cols-1 md:grid-cols-2 gap-6">
            {metadata.map((table) => (
              <div
                key={table.name}
                className="p-6 bg-slate-900/30 border border-slate-900 rounded-2xl hover:border-slate-800 transition-all duration-300 flex flex-col justify-between group"
              >
                <div>
                  <div className="flex items-center justify-between mb-4">
                    <h4 className="text-lg font-bold text-white group-hover:text-brand-400 transition-colors capitalize font-outfit">
                      {table.name.replace('_', ' ')}
                    </h4>
                    <span className="px-2.5 py-1 bg-brand-500/10 text-brand-400 border border-brand-500/10 rounded-lg text-xs font-semibold">
                      {table.count} row{table.count !== 1 ? 's' : ''}
                    </span>
                  </div>

                  <p className="text-xs text-slate-400 mb-4">
                    Contains {table.columns.length} columns:
                  </p>

                  <div className="flex flex-wrap gap-1.5 mb-6">
                    {table.columns.map((col) => (
                      <span
                        key={col.name}
                        className={`text-[10px] px-2 py-0.5 rounded-md font-mono ${
                          col.is_pk
                            ? 'bg-amber-500/10 text-amber-400 border border-amber-500/20'
                            : 'bg-slate-800 text-slate-300'
                        }`}
                      >
                        {col.name}: {col.type}
                      </span>
                    ))}
                  </div>
                </div>

                <Link
                  to={`/${table.name}`}
                  className="flex items-center gap-2 text-xs font-semibold text-slate-300 hover:text-white mt-auto group/btn transition-colors"
                >
                  Manage Records
                  <ArrowRight className="w-3.5 h-3.5 transform group-hover/btn:translate-x-1 transition-transform" />
                </Link>
              </div>
            ))}
          </div>
        )}
      </div>
    </div>
  )
}
