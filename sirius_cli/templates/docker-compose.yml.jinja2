version: '3.8'

services:
  backend:
    build:
      context: ./backend
      dockerfile: Dockerfile
    ports:
      - "{{ port }}:{{ port }}"
    volumes:
      - ./backend:/app/backend
    environment:
      - PORT={{ port }}

  frontend:
    build:
      context: ./frontend
      dockerfile: Dockerfile
    ports:
      - "5173:5173"
    volumes:
      - ./frontend:/app
      - /app/node_modules
    environment:
      - VITE_API_URL={{ api_url }}
    depends_on:
      - backend
