import React, { useEffect, useState, useCallback, useRef } from 'react'
import { useNavigate, useSearchParams } from 'react-router-dom'
import { Plus, X, Loader2, Search, Download, FileSpreadsheet } from 'lucide-react'
import { SiriusTable, ColumnSchema } from '../components/SiriusTable'
import { SiriusPagination } from '../components/SiriusPagination'
import { SiriusDropdown } from '../components/SiriusDropdown'
import { SiriusError } from '../components/SiriusError'
import { SiriusToast } from '../components/SiriusToast'
const API_BASE = import.meta.env.VITE_API_URL || 'http://localhost:8000'

interface RecordType {
  id: number
  [key: string]: any
}

export default function {{ table_name.replace('_', ' ').title().replace(' ', '') }}Crud() {
  const navigate = useNavigate()
  const [searchParams, setSearchParams] = useSearchParams()
  const [records, setRecords] = useState<RecordType[]>([])
  const [loading, setLoading] = useState(true)
  const [submitting, setSubmitting] = useState(false)
  const [error, setError] = useState<string | null>(null)
  const [highlightId, setHighlightId] = useState<number | null>(null)
  const [toast, setToast] = useState<{ message: string; type: 'success' | 'error' } | null>(null)
  const rowRefs = useRef<Record<number, HTMLTableRowElement | null>>({})

  const showToast = (message: string, type: 'success' | 'error') => {
    setToast({ message, type })
  }

  const tableSchema: ColumnSchema[] = [
    {% for col in columns %}
    {
      name: '{{ col.name }}',
      type: '{{ col.type }}',
      foreignKey: {% if col.foreign_key %}'{{ col.foreign_key }}'{% else %}null{% endif %},
      isPk: {% if col.is_pk %}true{% else %}false{% endif %},
      isRequired: {% if col.is_required %}true{% else %}false{% endif %}{% if col.enum_values is defined and col.enum_values %},
      enumValues: {{ col.enum_values | tojson }}{% endif %}{% if col.pattern is defined and col.pattern %},
      pattern: '{{ col.pattern }}'{% endif %}{% if col.placeholder is defined and col.placeholder %},
      placeholder: '{{ col.placeholder }}'{% endif %}
    },
    {% endfor %}
  ]

  // Pagination states
  const pageStr = searchParams.get('page')
  const page = pageStr ? parseInt(pageStr, 10) : 1
  const currentCursor = searchParams.get('cursor') || null
  const limit = 10
  const [cursorStack, setCursorStack] = useState<string[]>([])

  // Server-side search
  const [search, setSearch] = useState('')
  const [debouncedSearch, setDebouncedSearch] = useState('')

  // Sort states
  const [sortCol, setSortCol] = useState<string | null>(null)
  const [sortDir, setSortDir] = useState<'asc' | 'desc'>('asc')

  // Modal states
  const [isModalOpen, setIsModalOpen] = useState(false)
  const [editingRecord, setEditingRecord] = useState<RecordType | null>(null)
  
  // Options for foreign keys
  {% for col in columns %}
  {% if col.foreign_key %}
  {% set target_table = col.foreign_key.split('.')[0] %}
  const [{{ target_table }}Options, set{{ target_table.title().replace('_', '').replace(' ', '') }}Options] = useState<any[]>([])
  const [{{ target_table }}OptionsError, set{{ target_table.title().replace('_', '').replace(' ', '') }}OptionsError] = useState<string | null>(null)
  {% endif %}
  {% endfor %}

  // Form states
  const [formData, setFormData] = useState<Record<string, any>>({
    {% for col in columns %}
    {% if not col.is_pk %}
    {% if col.type == 'Boolean' %}
    {{ col.name }}: false,
    {% else %}
    {{ col.name }}: '',
    {% endif %}
    {% endif %}
    {% endfor %}
  })

  const [deleteConfirmId, setDeleteConfirmId] = useState<number | null>(null)

  // Debounce search input
  useEffect(() => {
    const timer = setTimeout(() => {
      setDebouncedSearch(prev => {
        if (prev !== search) {
          searchParams.delete('cursor')
          searchParams.set('page', '1')
          setSearchParams(searchParams)
          setCursorStack([])
        }
        return search
      })
    }, 350)
    return () => clearTimeout(timer)
  }, [search, searchParams, setSearchParams])

  // Handle ?highlight=ID param — scroll to and flash the row
  useEffect(() => {
    const idParam = searchParams.get('highlight')
    if (!idParam) return
    const id = parseInt(idParam, 10)
    setHighlightId(id)
    // Clear param from URL without re-navigating
    setSearchParams({}, { replace: true })

    // Check if the record exists (graceful 404 handling)
    fetch(`${API_BASE}/api/{{ table_name }}/${id}`{% if auth %}, { headers: { Authorization: `Bearer ${localStorage.getItem('token')}` } }{% endif %})
      .then(res => {
        if (res.status === 404) {
          showToast(`Record #${id} not found (it may have been deleted)`, 'error')
        }
      })
      .catch(() => {}) // Ignore network errors in this passive check

    // Scroll to row once records are loaded
    const tryScroll = () => {
      const el = rowRefs.current[id]
      if (el) {
        el.scrollIntoView({ behavior: 'smooth', block: 'center' })
      }
    }
    const timer = setTimeout(tryScroll, 300)
    // Auto-clear highlight after animation
    const clearTimer = setTimeout(() => setHighlightId(null), 2500)
    return () => { clearTimeout(timer); clearTimeout(clearTimer) }
  }, [searchParams, records])

  const fetchRecords = useCallback(async () => {
    try {
      setLoading(true)
      const params = new URLSearchParams({
        limit: String(limit + 1),
      })
      if (currentCursor) params.set('cursor', currentCursor)
      if (debouncedSearch) params.set('search', debouncedSearch)
      if (sortCol) {
        params.set('order_by', sortCol)
        params.set('dir', sortDir)
      }
      const res = await fetch(`${API_BASE}/api/{{ table_name }}?${params}`{% if auth %}, { headers: { Authorization: `Bearer ${localStorage.getItem('token')}` } }{% endif %})
      if (!res.ok) throw new Error('Failed to load data from server')
      const data = await res.json()
      setRecords(data)
      setError(null)
    } catch (err: any) {
      setError(err.message || 'Something went wrong')
    } finally {
      setLoading(false)
    }
  }, [currentCursor, debouncedSearch, sortCol, sortDir])

  useEffect(() => {
    fetchRecords()
  }, [fetchRecords])

  // Fetch Foreign Key Options
  useEffect(() => {
    {% for col in columns %}
    {% if col.foreign_key %}
    {% set target_table = col.foreign_key.split('.')[0] %}
    fetch(`${API_BASE}/api/{{ target_table }}?limit=500`{% if auth %}, { headers: { Authorization: `Bearer ${localStorage.getItem('token')}` } }{% endif %})
      .then(res => {
        if (!res.ok) throw new Error(`Server responded ${res.status}`)
        return res.json()
      })
      .then(data => set{{ target_table.title().replace('_', '').replace(' ', '') }}Options(data))
      .catch(err => {
        console.error("Failed to load options for {{ target_table }}", err)
        set{{ target_table.title().replace('_', '').replace(' ', '') }}OptionsError(err.message || 'Failed to load options')
      })
    {% endif %}
    {% endfor %}
  }, [])

  const foreignKeyOptions: Record<string, any[]> = {
    {% for col in columns %}
    {% if col.foreign_key %}
    {% set target_table = col.foreign_key.split('.')[0] %}
    '{{ target_table }}': {{ target_table }}Options,
    {% endif %}
    {% endfor %}
  }

  const handleInputChange = (e: React.ChangeEvent<HTMLInputElement | HTMLSelectElement>) => {
    const { name, type } = e.target
    if (type === 'checkbox') {
      const checked = (e.target as HTMLInputElement).checked
      setFormData(prev => ({ ...prev, [name]: checked }))
    } else {
      const value = e.target.value
      setFormData(prev => ({ ...prev, [name]: value }))
    }
  }

  const openCreateModal = () => {
    setEditingRecord(null)
    setFormData({
      {% for col in columns %}
      {% if not col.is_pk %}
      {% if col.type == 'Boolean' %}
      {{ col.name }}: false,
      {% else %}
      {{ col.name }}: '',
      {% endif %}
      {% endif %}
      {% endfor %}
    })
    setIsModalOpen(true)
  }

  const openEditModal = (record: RecordType) => {
    setEditingRecord(record)
    const mappedData = { ...record }
    {% for col in columns %}
    {% if col.type == 'DateTime' %}
    if (record.{{ col.name }}) {
      mappedData.{{ col.name }} = new Date(record.{{ col.name }}).toISOString().slice(0, 16)
    }
    {% endif %}
    {% endfor %}
    setFormData(mappedData)
    setIsModalOpen(true)
  }

  const handleSubmit = async (e: React.FormEvent) => {
    e.preventDefault()
    setSubmitting(true)
    try {
      const url = editingRecord 
        ? `${API_BASE}/api/{{ table_name }}/${editingRecord.id}` 
        : `${API_BASE}/api/{{ table_name }}`
      const method = editingRecord ? 'PUT' : 'POST'

      const payload: Record<string, any> = {}
      {% for col in columns %}
      {% if not col.is_pk %}
      {% if col.type == 'Integer' %}
      payload.{{ col.name }} = formData.{{ col.name }} !== '' && formData.{{ col.name }} !== null ? parseInt(formData.{{ col.name }}, 10) : null
      {% elif col.type == 'Float' %}
      payload.{{ col.name }} = formData.{{ col.name }} !== '' && formData.{{ col.name }} !== null ? parseFloat(formData.{{ col.name }}) : null
      {% elif col.type == 'Boolean' %}
      payload.{{ col.name }} = !!formData.{{ col.name }}
      {% elif col.type == 'DateTime' %}
      payload.{{ col.name }} = formData.{{ col.name }} !== '' && formData.{{ col.name }} !== null ? new Date(formData.{{ col.name }}).toISOString() : null
      {% else %}
      payload.{{ col.name }} = formData.{{ col.name }} || null
      {% endif %}
      {% endif %}
      {% endfor %}

      const res = await fetch(url, {
        method,
        headers: { 
          'Content-Type': 'application/json'{% if auth %},
          'Authorization': `Bearer ${localStorage.getItem('token')}`{% endif %}
        },
        body: JSON.stringify(payload)
      })

      if (!res.ok) throw new Error('Failed to save record')
      
      setIsModalOpen(false)
      fetchRecords()
      showToast(editingRecord ? 'Record updated successfully' : 'Record created successfully', 'success')
    } catch (err: any) {
      showToast(err.message || 'Error saving record', 'error')
    } finally {
      setSubmitting(false)
    }
  }

  const handleDelete = async (id: number) => {
    try {
      const res = await fetch(`${API_BASE}/api/{{ table_name }}/${id}`, {
        method: 'DELETE'{% if auth %},
        headers: { Authorization: `Bearer ${localStorage.getItem('token')}` }{% endif %}
      })
      if (!res.ok) throw new Error('Failed to delete record')
      setDeleteConfirmId(null)
      fetchRecords()
      showToast('Record deleted successfully', 'success')
    } catch (err: any) {
      showToast(err.message || 'Error deleting record', 'error')
    }
  }

  const handleExport = async (fmt: 'csv' | 'xlsx') => {
    {% if auth %}
    try {
      const res = await fetch(`${API_BASE}/api/{{ table_name }}/export?fmt=${fmt}`, {
        headers: { Authorization: `Bearer ${localStorage.getItem('token')}` }
      })
      if (!res.ok) throw new Error('Export failed')
      const blob = await res.blob()
      const url = window.URL.createObjectURL(blob)
      const a = document.createElement('a')
      a.href = url
      a.download = `{{ table_name }}.${fmt}`
      document.body.appendChild(a)
      a.click()
      a.remove()
      window.URL.revokeObjectURL(url)
    } catch (err: any) {
      alert(err.message || 'Export failed')
    }
    {% else %}
    window.open(`${API_BASE}/api/{{ table_name }}/export?fmt=${fmt}`, '_blank')
    {% endif %}
  }

  const handleSort = (colName: string) => {
    if (sortCol === colName) {
      setSortDir(prev => prev === 'asc' ? 'desc' : 'asc')
    } else {
      setSortCol(colName)
      setSortDir('asc')
    }
    searchParams.delete('cursor')
    searchParams.set('page', '1')
    setSearchParams(searchParams)
    setCursorStack([])
  }

  const hasNextPage = records.length > limit
  const displayedRecords = hasNextPage ? records.slice(0, limit) : records

  const handleNextPage = () => {
    if (!hasNextPage || displayedRecords.length === 0) return
    const lastRecord = displayedRecords[displayedRecords.length - 1]
    const sortVal = sortCol ? lastRecord[sortCol] : null
    const nextCursorData = { id: lastRecord.id, val: sortVal }
    const nextCursorString = btoa(JSON.stringify(nextCursorData))
    
    setCursorStack(prev => [...prev, currentCursor || ''])
    searchParams.set('cursor', nextCursorString)
    searchParams.set('page', String(page + 1))
    setSearchParams(searchParams)
  }

  const handlePrevPage = () => {
    if (page <= 1) return
    const prevCursor = cursorStack[cursorStack.length - 1]
    setCursorStack(prev => prev.slice(0, -1))
    if (prevCursor) {
      searchParams.set('cursor', prevCursor)
    } else {
      searchParams.delete('cursor')
    }
    searchParams.set('page', String(page - 1))
    setSearchParams(searchParams)
  }

  return (
    <div className="space-y-6">
      {/* Header Panel */}
      <div className="flex flex-col md:flex-row md:items-center justify-between gap-4">
        <div>
          <h2 className="text-2xl font-bold font-outfit text-white capitalize">
            {{ table_name.replace('_', ' ') }}
          </h2>
          <p className="text-slate-400 text-xs mt-1 font-sans">
            Create, update, and manage entries for {{ table_name }}.
          </p>
        </div>
        
        <div className="flex gap-2">
          <button
            onClick={() => handleExport('csv')}
            className="flex items-center gap-2 px-4 py-2.5 bg-slate-900 border border-slate-805 hover:bg-slate-800 rounded-xl text-xs font-semibold text-slate-300 transition-all"
          >
            <Download className="w-4 h-4 text-slate-400" />
            CSV
          </button>
          <button
            onClick={() => handleExport('xlsx')}
            className="flex items-center gap-2 px-4 py-2.5 bg-slate-900 border border-slate-805 hover:bg-slate-800 rounded-xl text-xs font-semibold text-slate-300 transition-all"
          >
            <FileSpreadsheet className="w-4 h-4 text-emerald-400" />
            Excel
          </button>
          <button
            onClick={openCreateModal}
            className="flex items-center gap-2 px-4 py-2.5 bg-gradient-to-r from-brand-600 to-brand-700 hover:from-brand-500 hover:to-brand-600 rounded-xl text-xs font-semibold shadow-lg shadow-brand-500/20 text-white transition-all"
          >
            <Plus className="w-4 h-4" />
            Add Record
          </button>
        </div>
      </div>

      {/* Search & Stats Bar */}
      <div className="flex flex-col sm:flex-row gap-4 items-center justify-between bg-slate-900/30 p-4 border border-slate-900 rounded-xl">
        <div className="relative w-full sm:w-85">
          <Search className="absolute left-3.5 top-1/2 -translate-y-1/2 w-4 h-4 text-slate-500" />
          <input
            type="text"
            placeholder="Search all records..."
            value={search}
            onChange={(e) => setSearch(e.target.value)}
            className="w-full pl-10 pr-4 py-2 bg-slate-950 border border-slate-800 rounded-xl text-xs focus:border-brand-500 focus:outline-none text-slate-300 transition-colors"
          />
        </div>
        <div className="text-xs text-slate-500 font-medium flex items-center gap-2">
          {debouncedSearch && (
            <span className="px-2 py-0.5 rounded-md bg-brand-500/10 border border-brand-500/20 text-brand-400 text-[10px] font-semibold">
              Server search
            </span>
          )}
          Showing {displayedRecords.length} record{displayedRecords.length !== 1 ? 's' : ''} on this page
        </div>
      </div>

      {/* Main Grid/Table */}
      {error ? (
        <SiriusError message={error} />
      ) : (
        <div className="flex flex-col gap-4">
          <div className="relative">
            <SiriusTable
              schema={tableSchema}
              records={displayedRecords}
              sortCol={sortCol}
              sortDir={sortDir}
              onSort={handleSort}
              onEdit={openEditModal}
              onDelete={handleDelete}
              deleteConfirmId={deleteConfirmId}
              setDeleteConfirmId={setDeleteConfirmId}
              highlightId={highlightId}
              rowRefs={rowRefs}
              foreignKeyOptions={foreignKeyOptions}
              loading={loading}
              onAdd={openCreateModal}
            />
            {loading && displayedRecords.length > 0 && (
              <div className="absolute inset-0 bg-slate-950/40 backdrop-blur-[1px] rounded-2xl flex items-center justify-center transition-all duration-300">
                <div className="flex items-center gap-3 px-4 py-2.5 bg-slate-900 border border-slate-800 rounded-xl shadow-xl">
                  <Loader2 className="w-4 h-4 text-brand-500 animate-spin" />
                  <span className="text-xs text-slate-300 font-medium">Updating...</span>
                </div>
              </div>
            )}
          </div>
          {!loading && displayedRecords.length > 0 && (
            <SiriusPagination 
              page={page}
              hasNextPage={hasNextPage}
              onPrevPage={handlePrevPage}
              onNextPage={handleNextPage}
            />
          )}
        </div>
      )}

      {/* Create / Edit Modal */}
      {isModalOpen && (
        <div className="fixed inset-0 z-50 flex items-center justify-center p-4 bg-slate-950/80 backdrop-blur-sm">
          <div className="w-full max-w-lg bg-slate-900 border border-slate-850 rounded-2xl shadow-2xl flex flex-col max-h-[90vh]">
            <header className="px-6 py-4 border-b border-slate-850 flex items-center justify-between">
              <h3 className="font-outfit font-bold text-white text-base">
                {editingRecord ? 'Update Record' : 'Create New Record'}
              </h3>
              <button
                onClick={() => setIsModalOpen(false)}
                className="text-slate-400 hover:text-white p-1 hover:bg-slate-800 rounded-lg transition-all"
              >
                <X className="w-4 h-4" />
              </button>
            </header>

            <form onSubmit={handleSubmit} className="p-6 overflow-y-auto space-y-4 flex-1">
              {% for col in columns %}
              {% if not col.is_pk %}
              <div className="flex flex-col gap-1.5">
                <label className="text-[10px] font-bold text-slate-400 uppercase tracking-wider font-outfit">
                  {{ col.name.replace('_', ' ') }}
                </label>
                
                {% if col.foreign_key %}
                {% set target_table = col.foreign_key.split('.')[0] %}
                <SiriusDropdown
                  name="{{ col.name }}"
                  value={formData.{{ col.name }}}
                  onChange={handleInputChange}
                  options={ {{ target_table }}Options }
                  error={ {{ target_table }}OptionsError }
                  targetTable="{{ target_table }}"
                  required={ {% if col.is_required %}true{% else %}false{% endif %} }
                />

                {% elif col.type == 'Boolean' %}
                <div className="flex items-center gap-3 py-2">
                  <input
                    type="checkbox"
                    id="{{ col.name }}_field"
                    name="{{ col.name }}"
                    checked={formData.{{ col.name }} || false}
                    onChange={handleInputChange}
                    className="w-4.5 h-4.5 accent-brand-650 bg-slate-950 border border-slate-800 rounded focus:ring-0 focus:outline-none"
                  />
                  <label htmlFor="{{ col.name }}_field" className="text-xs text-slate-300">
                    Enable
                  </label>
                </div>

                {% elif col.type == 'Integer' %}
                <input
                  type="number"
                  step="1"
                  {% if col.min_val is defined %}min="{{ col.min_val }}"{% endif %}
                  {% if col.max_val is defined %}max="{{ col.max_val }}"{% endif %}
                  name="{{ col.name }}"
                  value={formData.{{ col.name }} !== undefined && formData.{{ col.name }} !== null ? formData.{{ col.name }} : ''}
                  onChange={handleInputChange}
                  {% if col.is_required %}required{% endif %}
                  className="px-3 py-2 bg-slate-950 border border-slate-800 rounded-xl text-xs focus:border-brand-500 focus:outline-none text-slate-200 transition-colors"
                />

                {% elif col.type == 'Float' %}
                <input
                  type="number"
                  step="any"
                  {% if col.min_val is defined %}min="{{ col.min_val }}"{% endif %}
                  {% if col.max_val is defined %}max="{{ col.max_val }}"{% endif %}
                  name="{{ col.name }}"
                  value={formData.{{ col.name }} !== undefined && formData.{{ col.name }} !== null ? formData.{{ col.name }} : ''}
                  onChange={handleInputChange}
                  {% if col.is_required %}required{% endif %}
                  className="px-3 py-2 bg-slate-950 border border-slate-800 rounded-xl text-xs focus:border-brand-500 focus:outline-none text-slate-200 transition-colors"
                />

                {% elif col.type == 'DateTime' %}
                <input
                  type="datetime-local"
                  name="{{ col.name }}"
                  value={formData.{{ col.name }} || ''}
                  onChange={handleInputChange}
                  {% if col.is_required %}required{% endif %}
                  className="px-3 py-2 bg-slate-950 border border-slate-800 rounded-xl text-xs focus:border-brand-500 focus:outline-none text-slate-200 transition-colors"
                />

                 {% elif col.enum_values is defined and col.enum_values %}
                <select
                  name="{{ col.name }}"
                  value={formData.{{ col.name }} || ''}
                  onChange={handleInputChange}
                  {% if col.is_required %}required{% endif %}
                  className="px-3 py-2 bg-slate-950 border border-slate-800 rounded-xl text-xs focus:border-brand-500 focus:outline-none text-slate-200 transition-colors"
                >
                  <option value="">Select {{ col.name.replace('_', ' ') }}...</option>
                  {% for val in col.enum_values %}
                  <option value="{{ val }}">{{ val }}</option>
                  {% endfor %}
                </select>

                {% else %}
                <input
                  type="{% if 'email' in col.name %}email{% else %}text{% endif %}"
                  name="{{ col.name }}"
                  value={formData.{{ col.name }} || ''}
                  onChange={handleInputChange}
                  {% if col.is_required %}required{% endif %}
                  {% if col.pattern is defined and col.pattern %}pattern="{{ col.pattern }}"{% endif %}
                  {% if col.placeholder is defined and col.placeholder %}placeholder="{{ col.placeholder }}"{% endif %}
                  {% if col.placeholder is defined and col.placeholder %}title="Expected format: {{ col.placeholder }}"{% endif %}
                  className="px-3 py-2 bg-slate-950 border border-slate-800 rounded-xl text-xs focus:border-brand-500 focus:outline-none text-slate-200 transition-colors"
                />
                {% endif %}
              </div>
              {% endif %}
              {% endfor %}

              <div className="pt-4 border-t border-slate-850 flex items-center justify-end gap-3">
                <button
                  type="button"
                  onClick={() => setIsModalOpen(false)}
                  className="px-4 py-2 bg-slate-800 hover:bg-slate-750 text-slate-300 font-semibold text-xs rounded-xl transition-all"
                >
                  Cancel
                </button>
                <button
                  type="submit"
                  disabled={submitting}
                  className="flex items-center gap-1.5 px-4 py-2 bg-brand-600 hover:bg-brand-500 text-white font-semibold text-xs rounded-xl disabled:opacity-50 transition-all shadow-lg shadow-brand-500/10"
                >
                  {submitting && <Loader2 className="w-3.5 h-3.5 animate-spin" />}
                  Save
                </button>
              </div>
            </form>
          </div>
        </div>
      )}

      {/* Toast Notification */}
      {toast && (
        <SiriusToast 
          message={toast.message} 
          type={toast.type} 
          onClose={() => setToast(null)} 
        />
      )}
    </div>
  )
}

