{% raw %}
import React, { useEffect } from 'react'
import { CheckCircle2, AlertCircle, X } from 'lucide-react'

interface SiriusToastProps {
  message: string;
  type: 'success' | 'error';
  onClose: () => void;
  duration?: number;
}

export function SiriusToast({ message, type, onClose, duration = 3000 }: SiriusToastProps) {
  useEffect(() => {
    const timer = setTimeout(() => {
      onClose()
    }, duration)
    return () => clearTimeout(timer)
  }, [onClose, duration])

  return (
    <div className="fixed bottom-6 right-6 z-50 flex items-center gap-3 px-4 py-3 rounded-xl border backdrop-blur-md shadow-2xl transition-all duration-300 animate-slide-in bg-slate-900/90 border-slate-800 text-slate-100 max-w-sm">
      {type === 'success' ? (
        <CheckCircle2 className="w-5 h-5 text-emerald-400 shrink-0" />
      ) : (
        <AlertCircle className="w-5 h-5 text-red-400 shrink-0" />
      )}
      <p className="text-xs font-semibold font-outfit">{message}</p>
      <button 
        onClick={onClose} 
        className="ml-auto p-0.5 hover:bg-slate-800 rounded-md text-slate-400 hover:text-slate-200 transition-all cursor-pointer"
      >
        <X className="w-3.5 h-3.5" />
      </button>
    </div>
  )
}
{% endraw %}
