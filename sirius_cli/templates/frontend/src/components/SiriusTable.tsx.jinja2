{% raw %}
import React from 'react'
import { ArrowUpDown, ArrowUp, ArrowDown, Edit2, Trash2 } from 'lucide-react'
import { useNavigate } from 'react-router-dom'
import { SiriusBadge } from './SiriusBadge'

export interface ColumnSchema {
  name: string;
  type: string;
  foreignKey: string | null;
  isPk: boolean;
  isRequired: boolean;
  enumValues?: string[];
  pattern?: string;
  placeholder?: string;
}

interface SiriusTableProps {
  schema: ColumnSchema[];
  records: any[];
  sortCol: string | null;
  sortDir: 'asc' | 'desc';
  onSort: (colName: string) => void;
  onEdit: (record: any) => void;
  onDelete: (id: number) => void;
  deleteConfirmId: number | null;
  setDeleteConfirmId: (id: number | null) => void;
  highlightId: number | null;
  rowRefs: React.MutableRefObject<Record<number, HTMLTableRowElement | null>>;
  foreignKeyOptions: Record<string, any[]>;
}

export function SiriusTable({
  schema,
  records,
  sortCol,
  sortDir,
  onSort,
  onEdit,
  onDelete,
  deleteConfirmId,
  setDeleteConfirmId,
  highlightId,
  rowRefs,
  foreignKeyOptions
}: SiriusTableProps) {
  const navigate = useNavigate()

  const SortIcon = ({ col }: { col: string }) => {
    if (sortCol !== col) return <ArrowUpDown className="w-3 h-3 text-slate-600" />
    return sortDir === 'asc' ? <ArrowUp className="w-3 h-3 text-brand-400" /> : <ArrowDown className="w-3 h-3 text-brand-400" />
  }

  return (
    <div className="bg-slate-900/20 border border-slate-900 rounded-2xl overflow-hidden">
      <div className="overflow-x-auto">
        <table className="w-full text-left border-collapse">
          <thead>
            <tr className="border-b border-slate-900 bg-slate-900/50">
              {schema.map((col) => (
                <th
                  key={col.name}
                  onClick={() => onSort(col.name)}
                  className="px-6 py-4 text-xs font-bold text-slate-400 uppercase font-outfit tracking-wider cursor-pointer hover:text-slate-200 select-none transition-colors"
                >
                  <div className="flex items-center gap-1.5">
                    {col.name.replace('_', ' ')}
                    <SortIcon col={col.name} />
                  </div>
                </th>
              ))}
              <th className="px-6 py-4 text-xs font-bold text-slate-400 uppercase font-outfit tracking-wider text-right">
                Actions
              </th>
            </tr>
          </thead>
          <tbody className="divide-y divide-slate-900">
            {records.map((record) => (
              <tr
                key={record.id}
                ref={el => { rowRefs.current[record.id] = el }}
                className={`transition-colors ${
                  highlightId === record.id
                    ? 'bg-brand-500/10 ring-1 ring-inset ring-brand-500/40 animate-pulse'
                    : 'hover:bg-slate-900/30'
                }`}
              >
                {schema.map((col) => (
                  <td key={col.name} className="px-6 py-4 text-xs font-medium text-slate-300 font-mono">
                    {(() => {
                      if (col.type === 'Boolean') {
                        return <SiriusBadge value={record[col.name]} />
                      }
                      
                      if (col.type === 'DateTime') {
                        return record[col.name] ? new Date(record[col.name]).toLocaleString() : '-'
                      }
                      
                      if (col.foreignKey) {
                        const targetTable = col.foreignKey.split('.')[0]
                        const options = foreignKeyOptions[targetTable] || []
                        const opt = options.find((o: any) => o.id === record[col.name])
                        
                        let displayValue = record[col.name] !== null ? `${targetTable} #${record[col.name]}` : '-'
                        if (opt) {
                          displayValue = opt.name || opt.username || opt.email || opt.title || opt.label || `${targetTable} #${opt.id}`
                        }
                        
                        return (
                          <button
                            onClick={() => record[col.name] !== null && navigate(`/${targetTable}?highlight=${record[col.name]}`)}
                            className="px-2 py-0.5 rounded bg-slate-800/80 text-brand-400 border border-slate-700/40 text-[10px] font-bold cursor-pointer hover:bg-slate-700/60 hover:border-brand-500/30 transition-all"
                            title={`Go to ${targetTable} record`}
                          >
                            {displayValue}
                          </button>
                        )
                      }
                      
                      return record[col.name] !== null && record[col.name] !== undefined ? String(record[col.name]) : '-'
                    })()}
                  </td>
                ))}
                
                <td className="px-6 py-4 text-right">
                  <div className="flex items-center justify-end gap-2">
                    <button
                      onClick={() => onEdit(record)}
                      className="p-1.5 hover:bg-slate-800 text-slate-400 hover:text-white rounded-lg transition-all"
                    >
                      <Edit2 className="w-3.5 h-3.5" />
                    </button>
                    {deleteConfirmId === record.id ? (
                      <div className="flex items-center gap-1.5">
                        <button
                          onClick={() => onDelete(record.id)}
                          className="px-2 py-1 bg-red-600 hover:bg-red-500 text-[10px] text-white font-bold rounded-md"
                        >
                          Confirm
                        </button>
                        <button
                          onClick={() => setDeleteConfirmId(null)}
                          className="px-2 py-1 bg-slate-800 hover:bg-slate-700 text-[10px] text-slate-300 rounded-md"
                        >
                          Cancel
                        </button>
                      </div>
                    ) : (
                      <button
                        onClick={() => setDeleteConfirmId(record.id)}
                        className="p-1.5 hover:bg-red-950/40 text-slate-400 hover:text-red-400 rounded-lg transition-all"
                      >
                        <Trash2 className="w-3.5 h-3.5" />
                      </button>
                    )}
                  </div>
                </td>
              </tr>
            ))}
          </tbody>
        </table>
      </div>
    </div>
  )
}
{% endraw %}
